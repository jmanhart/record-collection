{
  "name": "records.manhart.io",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/copyArticles.js && vite",
    "build": "node scripts/copyArticles.js && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "generate-readme": "node scripts/generateReadme.cjs",
    "sync:discogs": "pnpm --filter discogs-supabase-sync run fetch",
    "sync:readme": "pnpm run generate-readme",
    "sync:discography": "pnpm --filter discogs-supabase-sync run sync:discography",
    "sync:track-durations": "pnpm --filter discogs-supabase-sync run track-durations",
    "report:track-durations": "pnpm --filter discogs-supabase-sync run report:track-durations",
    "sync:all": "pnpm run sync:discogs && pnpm run sync:readme",
    "tools:dev": "pnpm --filter discogs-supabase-sync run dev",
    "article:new": "node scripts/newArticle.js",
    "backup": "node scripts/backup.cjs",
    "backup:push": "node scripts/backup.cjs --push",
    "restore": "node scripts/restore.cjs",
    "restore:execute": "node scripts/restore.cjs --execute"
  },
  "dependencies": {
    "@mdx-js/react": "^3.0.1",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@sentry/browser": "^9.45.0",
    "@sentry/react": "^9.45.0",
    "@sentry/replay": "^7.116.0",
    "@sentry/tracing": "^7.120.3",
    "@sentry/vite-plugin": "^3.3.1",
    "@supabase/supabase-js": "^2.39.8",
    "@tanstack/react-query": "^5.24.1",
    "lucide-react": "^0.341.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.0",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@mdx-js/rollup": "^3.0.1",
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "globals": "^13.24.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2",
    "typescript-eslint": "^7.18.0",
    "vite": "^5.1.6"
  }
}
